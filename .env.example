# ─────────────────────────────────────────────────────────────────────────────
# TENET — Root Environment Configuration
# Copy this to .env and fill in real values before running
#
# The telegram-bot/ subdirectory also reads from this file when launched
# with PM2 from the repo root. For local dev inside telegram-bot/, use
# telegram-bot/.env instead.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
BOT_NAME=TENET
ADMIN_IDS=123456789,987654321
# Optional — Telegram chat ID that receives /support escalations
HUMAN_MODERATOR_CHAT_ID=

# ── Database (PostgreSQL — optional) ──────────────────────────────────────────
DATABASE_URL=postgresql://botuser:your_postgres_password_here@localhost:5432/botdb

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI: AWS Bedrock (primary LLM + embeddings) ────────────────────────────────
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
AWS_REGION=eu-north-1
AI_MODEL=openai.gpt-oss-120b-1:0

# ── AI: Anthropic (optional — health-check only) ──────────────────────────────
AI_API_KEY=your_anthropic_api_key_here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
