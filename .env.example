# Super Bot v3.0 — Root Environment Configuration
# Copy to .env and fill in your values before running

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_IDS=123456789,987654321
# Telegram Chat ID that receives escalation / support alerts (optional)
HUMAN_MODERATOR_CHAT_ID=

# Database (PostgreSQL)
DATABASE_URL=postgresql://botuser:your_postgres_password_here@localhost:5432/botdb

# Redis
REDIS_URL=redis://localhost:6379

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Default Claude model: claude-3-5-sonnet-20241022 or anthropic.claude-3-haiku-20240307-v1:0
AI_MODEL=claude-3-5-sonnet-20241022

# AWS (For Bedrock AI and Vector Search)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Logging
LOG_LEVEL=info
