{
    "name": "super-bot",
    "version": "3.0.0",
    "description": "Production-ready Telegram bot system with Anthropic Claude AI",
    "main": "index.js",
    "scripts": {
        "install": "npm run install:shared && npm run install:telegram",
        "install:shared": "cd shared && npm install",
        "install:telegram": "cd telegram-bot && npm install",
        "build": "npm run build:shared && npm run build:telegram",
        "build:shared": "cd shared && npm run build",
        "build:telegram": "cd telegram-bot && npm run build",
        "test": "npm run test:shared && npm run test:telegram",
        "test:shared": "cd shared && npm test",
        "test:telegram": "cd telegram-bot && npm test",
        "typecheck": "npm run typecheck:shared && npm run typecheck:telegram",
        "typecheck:shared": "cd shared && npx tsc --noEmit",
        "typecheck:telegram": "cd telegram-bot && npx tsc --noEmit",
        "lint": "npm run lint:shared && npm run lint:telegram",
        "lint:shared": "cd shared && npm run lint",
        "lint:telegram": "cd telegram-bot && npm run lint",
        "dev": "cd telegram-bot && npm run dev",
        "start": "cd telegram-bot && npm start"
    },
    "keywords": [
        "telegram",
        "bot",
        "moderation",
        "anthropic",
        "claude",
        "ai",
        "typescript"
    ],
    "author": "zakky8",
    "license": "MIT",
    "devDependencies": {
        "concurrently": "^8.2.2",
        "typescript": "^5.3.3"
    }
}
