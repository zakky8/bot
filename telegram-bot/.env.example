# ─────────────────────────────────────────────────────────────────────────────
# TENET Telegram Bot — Environment Configuration
# Copy this to .env and fill in your real values before running
# ─────────────────────────────────────────────────────────────────────────────

# ── Bot Identity ──────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here
# Display name shown in AI replies (defaults to "TENET")
BOT_NAME=TENET

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL — optional; bot falls back gracefully if absent
DATABASE_URL=postgresql://username:password@localhost:5432/telegram_bot
POSTGRES_PASSWORD=your_postgres_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
# Optional — falls back to in-memory MemoryRedis if not set
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Permissions ───────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs of bot admins
ADMIN_IDS=123456789,987654321
# Telegram chat ID that receives /support escalations and human-help alerts
HUMAN_MODERATOR_CHAT_ID=

# ── AI: AWS Bedrock (primary LLM + embeddings) ────────────────────────────────
# Required for AI commands (/ask, /support, /adddoc, etc.)
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
AWS_REGION=eu-north-1
# Bedrock model ID used by quickChat (LangGraph generate node)
AI_MODEL=openai.gpt-oss-120b-1:0

# ── AI: Anthropic (optional — used only by /aisetup health check) ─────────────
AI_API_KEY=your_anthropic_api_key_here
