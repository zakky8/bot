# AWS Bedrock — same keys as telegram-bot .env
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_REGION=eu-north-1
AI_MODEL=openai.gpt-oss-20b-1:0

# Redis — same as telegram-bot .env
REDIS_URL=redis://redis:6379

# PostgreSQL — same as telegram-bot .env
DATABASE_URL=postgresql://botuser:your_postgres_password@postgres:5432/botdb

# Telegram — same as telegram-bot .env
BOT_TOKEN=your_telegram_bot_token
HUMAN_MODERATOR_CHAT_ID=your_moderator_chat_id

# Paths (auto-detected via ~/ if not set)
VECTOR_DB_PATH=
FAQ_DATA_PATH=

# FastAPI port
PORT=8001
